APP_NAME=altegio_bot
ENV=dev

DATABASE_URL=***

# query param "secret" из твоих логов вебхука
ALTEGIO_WEBHOOK_SECRET=***

WHATSAPP_PROVIDER=meta_cloud
ALLOW_REAL_SEND=1
STOP_WORKER_ON_TOKEN_EXPIRED=1

WHATSAPP_ACCESS_TOKEN=***
WHATSAPP_WEBHOOK_VERIFY_TOKEN=***
META_WA_PHONE_NUMBER_ID=***
META_WABA_ID=***
WHATSAPP_GRAPH_URL=https://graph.facebook.com
WHATSAPP_API_VERSION=v20.0

# Ops-cabinet access (at least one must be set, or leave both empty for dev)
# Token auth: curl -H "X-Ops-Token: secret" http://localhost:8000/ops/monitoring
OPS_TOKEN=
# Browser form login (recommended): set OPS_USER + OPS_PASS, then open /ops/ in a browser
OPS_USER=
OPS_PASS=
# Optional: separate secret for signing session cookies (defaults to OPS_PASS when empty)
OPS_SECRET=

# marketing_only = block only marketing jobs on opt-out; all = block all WA messages
WA_OPTOUT_POLICY=marketing_only

# Minutes after which a 'processing' job is considered stuck (default: 15)
OPS_STUCK_MINUTES=15

# Warn on monitoring page if failed outbox count exceeds this (default: 10)
OPS_FAILED_WARNING_THRESHOLD=10

# IANA timezone for local time display (default: Europe/Berlin)
OPS_LOCAL_TZ=Europe/Berlin

